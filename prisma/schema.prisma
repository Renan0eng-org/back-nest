// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnumUserType {
  ADMIN
  USUARIO
  MEDICO
  PACIENTE
}

enum Sex {
  FEMININO
  MASCULINO
  OUTRO
}

model User {
  idUser         String       @id @default(cuid())
  name           String
  avatar         String?
  email          String       @unique
  password       String
  cpf            String       @unique
  cep            String?
  phone          String?
  user_id_create String?
  user_id_update String?
  user_id_delete String?
  dt_delete      DateTime?
  created        DateTime     @default(now())
  updated        DateTime?    @updatedAt
  active         Boolean      @default(false)
  nivelAcessoId  Int          @default(1)
  nivel_acesso   Nivel_Acesso @relation(fields: [nivelAcessoId], references: [idNivelAcesso])
  type           EnumUserType @default(PACIENTE)
  birthDate      DateTime? 
  sexo           Sex? 
  unidadeSaude   String? 
  medicamentos   String? 
  exames         Boolean?  @default(false)
  examesDetalhes String?
  alergias       String?
  autoCadastro   Boolean?    @default(false)
  alta           Boolean     @default(false)
  altaAt         DateTime?
  emailVerified   Boolean    @default(false)
  emailVerifiedAt DateTime?

  fromAssigned   Form[] @relation("FormAssignedUsers")

  formResponses Response[]

  appointmentsProfessional Appointment[] @relation("AppointmentProfessional")
  appointmentsDoctor Appointment[] @relation("AppointmentDoctor")
  appointmentsPatient  Appointment[] @relation("AppointmentPatient")

  attendancesPatient       Attendance[] @relation("AttendancePatient")
  attendancesProfessional  Attendance[] @relation("AttendanceProfessional")
  attendancesCreated       Attendance[] @relation("AttendanceCreator")

  errorLogs     ErrorLog[]

  // Back-relations for notifications system
  createdNotifications Notification[] @relation("NotificationCreatedBy")
  userNotifications   UserNotification[]
  pushSubscriptions   PushSubscription[]
  
  // Chat relations
  chats         Chat[]
  chatLogs      ChatLog[]

  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  // Groups
  gruposMembro  Grupo_Membro[]
  gruposCriados Grupo[] @relation("GrupoCreator")
  formsCriados  Form[]  @relation("FormCreator")

  // Grupo ao qual o paciente pertence (para escopo de visualização)
  grupoPacienteId Int?
  grupoPaciente   Grupo? @relation("GrupoPacientes", fields: [grupoPacienteId], references: [idGrupo])

  // Módulo hospitalar — dados de médico (quando type = MEDICO)
  crm           String?
  especialidade String?
  cargaHoraria  Int?
  medicoStatus  DoctorStatus?

  plantoes            Plantao[]     @relation("PlantaoDoctor")
  queueTicketsPatient QueueTicket[] @relation("QueuePatient")
  queueTicketsDoctor  QueueTicket[] @relation("QueueDoctor")

  @@index([idUser])
  @@index([user_id_create])
  @@index([user_id_update])
  @@index([user_id_delete])
}

model Nivel_Acesso {
  idNivelAcesso Int                    @id @default(autoincrement())
  nome          String
  descricao     String?
  users         User[]
  menus         Menu_Acesso[]
  permissoes    Nivel_Menu_Permissao[]

  @@index([idNivelAcesso])
}

model Menu_Acesso {
  idMenuAcesso Int                    @id @default(autoincrement())
  nome         String
  slug         String                 @unique
  nivel_acesso Nivel_Acesso[]
  visualizar   Boolean                @default(false)
  criar        Boolean                @default(false)
  editar       Boolean                @default(false)
  excluir      Boolean                @default(false)
  relatorio    Boolean                @default(false)
  permissoes   Nivel_Menu_Permissao[]
}

model Nivel_Menu_Permissao {
  id            Int          @id @default(autoincrement())
  nivelAcessoId Int
  menuAcessoId  Int
  visualizar    Boolean      @default(false)
  criar         Boolean      @default(false)
  editar        Boolean      @default(false)
  excluir       Boolean      @default(false)
  relatorio     Boolean      @default(false)

  nivel_acesso  Nivel_Acesso @relation(fields: [nivelAcessoId], references: [idNivelAcesso], onDelete: Cascade)
  menu_acesso   Menu_Acesso  @relation(fields: [menuAcessoId], references: [idMenuAcesso], onDelete: Cascade)

  @@unique([nivelAcessoId, menuAcessoId])
  @@index([nivelAcessoId])
  @@index([menuAcessoId])
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_TEXT
  PARAGRAPH
  CHECKBOXES
}

model Form {
  idForm          String     @id @default(uuid())
  title       String
  description String?
  questions   Question[]
  responses   Response[]
  assignedUsers  User[] @relation("FormAssignedUsers")
  assignedAttendances  Attendance[] @relation("FormAssignedAttendances")
  scoreRules  ScoreRule[]
  createdById String?
  createdBy   User?      @relation("FormCreator", fields: [createdById], references: [idUser])
  grupoId     Int?
  grupo       Grupo?     @relation("GrupoFormularios", fields: [grupoId], references: [idGrupo])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isScreening Boolean    @default(false)
  active      Boolean    @default(true)

  @@index([createdById])
  @@index([grupoId])
}

model ScoreRule {
  idScoreRule    String  @id @default(uuid())
  minScore       Int
  maxScore       Int
  classification String
  conduct        String
  targetUserId   String?
  order          Int     @default(0)

  form   Form   @relation(fields: [formId], references: [idForm], onDelete: Cascade)
  formId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formId])
  @@index([minScore, maxScore])
}

model Question {
  idQuestion       String       @id @default(uuid())
  text     String
  type     QuestionType
  required Boolean      @default(false)
  order    Int
  form     Form         @relation(fields: [formId], references: [idForm], onDelete: Cascade)
  formId   String
  options  Option[]
  answers  Answer[]
}

model Option {
  idOption         String   @id @default(uuid())
  text       String
  value    Int?
  order      Int
  question   Question @relation(fields: [questionId], references: [idQuestion], onDelete: Cascade)
  questionId String
}


model Response {
  idResponse          String   @id @default(uuid())
  submittedAt DateTime @default(now())

  form   Form   @relation(fields: [formId], references: [idForm], onDelete: Cascade)
  formId String

  user   User   @relation(fields: [userId], references: [idUser])
  userId String

  observations String?

  // Score-based classification
  totalScore      Int?
  classification  String?
  conduct         String?
  assignedToId    String?

  answers Answer[]

  // Appointments that reference this response (optional)
  appointments Appointment[]
  attendanceResponses AttendanceResponse[] @relation("AttendanceResponses")

  @@index([formId])
  @@index([userId])
  @@index([assignedToId])
}

model Answer {
  idAnswer  String @id @default(uuid())

  value String?

  values String[]

  response   Response @relation(fields: [responseId], references: [idResponse], onDelete: Cascade)
  responseId String

  question   Question @relation(fields: [questionId], references: [idQuestion], onDelete: Cascade)
  questionId String

  @@index([responseId])
  @@index([questionId])
}


enum AppointmentStatus {
  Pendente
  Confirmado
  Cancelado
  Completo
}

model Appointment {
  id               String            @id @default(cuid())
  professionalId   String?
  doctorId         String?
  patientId        String
  responseId       String?
  scheduledAt      DateTime
  status           AppointmentStatus @default(Pendente)
  notes            String?
  totalScoreAtTime Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @updatedAt

  professional User?     @relation("AppointmentProfessional", fields: [professionalId], references: [idUser])
  doctor   User?     @relation("AppointmentDoctor", fields: [doctorId], references: [idUser])
  patient  User      @relation("AppointmentPatient", fields: [patientId], references: [idUser])
  response Response? @relation(fields: [responseId], references: [idResponse])
  
  attendances Attendance[]

  @@index([doctorId])
  @@index([patientId])
  @@index([scheduledAt])
}

enum AttendanceStatus {
  EmAndamento
  Concluido
  Cancelado
}

model Attendance {
  id                  String           @id @default(cuid())
  appointmentId       String?
  patientId           String
  professionalId      String
  attendanceDate      DateTime
  
  // Informações Clínicas
  chiefComplaint      String?          // Queixa principal
  presentingIllness   String?          // História da doença atual
  medicalHistory      String?          // Histórico médico
  physicalExamination String?          // Exame físico
  diagnosis           String?          // Diagnóstico
  treatment           String?          // Tratamento recomendado
  
  // Métricas Vitais
  bloodPressure       String?          // Ex: 120/80
  heartRate           Int?             // Batimentos por minuto
  temperature         Decimal?  @db.Decimal(5, 2)  // Em Celsius
  respiratoryRate     Int?             // Respirações por minuto
  
  // Status
  status              AttendanceStatus @default(EmAndamento)
  
  // Auditoria
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  createdBy           String?
  
  // Relações
  appointment         Appointment?     @relation(fields: [appointmentId], references: [id])
  patient             User             @relation("AttendancePatient", fields: [patientId], references: [idUser])
  professional        User             @relation("AttendanceProfessional", fields: [professionalId], references: [idUser])
  creator             User?            @relation("AttendanceCreator", fields: [createdBy], references: [idUser])
  
  assignedForms       Form[]           @relation("FormAssignedAttendances")
  responses           AttendanceResponse[]
  prescriptions       AttendancePrescription[]
  attachments         AttendanceAttachment[]
  medicalNotes        MedicalNote[]
  
  @@index([appointmentId])
  @@index([patientId])
  @@index([professionalId])
  @@index([attendanceDate])
  @@index([status])
}

model MedicalNote {
  id            String     @id @default(cuid())
  attendanceId  String
  title         String     // Ex: "Queixa Principal", "Diagnóstico", "Notas Adicionais"
  content       String     @db.Text  // HTML ou texto plano
  mode          String     @default("simple")  // "advanced" (Quill) ou "simple" (Textarea)
  order         Int        @default(0)  // Ordem de exibição
  allowFutureUse Boolean   @default(false) // Indica se pode ser reutilizada em outros atendimentos
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  
  @@index([attendanceId])
  @@index([attendanceId, order])
}

model AttendancePrescription {
  id            String     @id @default(cuid())
  attendanceId  String
  medication    String
  dosage        String     // Ex: "500mg"
  frequency     String     // Ex: "8 em 8 horas"
  duration      String     // Ex: "10 dias"
  instructions  String?
  createdAt     DateTime   @default(now())
  
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  
  @@index([attendanceId])
}

model AttendanceAttachment {
  id            String     @id @default(cuid())
  attendanceId  String
  fileName      String
  fileUrl       String     @db.VarChar(512)
  fileType      String?    // Ex: "image/jpeg", "application/pdf"
  uploadedAt    DateTime   @default(now())
  
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  
  @@index([attendanceId])
}

model AttendanceResponse {
  id            String     @id @default(cuid())
  attendanceId  String
  responseId    String
  createdAt     DateTime   @default(now())
  
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  response      Response   @relation("AttendanceResponses", fields: [responseId], references: [idResponse], onDelete: Cascade)
  
  @@unique([attendanceId, responseId])
  @@index([attendanceId])
  @@index([responseId])
}

model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  stack      String?
  method     String?
  route      String?
  statusCode Int?
  userId     String?
  user       User?    @relation(fields: [userId], references: [idUser])
  userEmail  String?
  ip         String?
  userAgent  String?
  forwardedFor String?
  seen       Boolean  @default(false)
  file       String?
  line       Int?
  column     Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Notifications
enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model Notification {
  id           String  @id @default(uuid())
  title        String
  body         String?
  data         Json?
  category     String?
  priority     Int     @default(0)
  createdAt    DateTime @default(now())

  createdById  String?
  createdBy    User?    @relation("NotificationCreatedBy", fields: [createdById], references: [idUser])

  userNotifications UserNotification[]

  @@index([createdAt])
  @@index([category])
}

model UserNotification {
  id             String  @id @default(uuid())
  status         NotificationStatus @default(UNREAD)
  deliveredAt    DateTime?
  readAt         DateTime?
  muted          Boolean @default(false)
  createdAt      DateTime @default(now())

  // Relations
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])

  userId         String
  user           User @relation(fields: [userId], references: [idUser])

  @@unique([notificationId, userId])
  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id           String   @id @default(uuid())
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime @default(now())
  lastSuccessAt DateTime?
  disabledAt   DateTime?

  userId       String
  user         User     @relation(fields: [userId], references: [idUser])

  @@index([userId])
}

enum ChatRole {
  USER
  ASSISTANT
}

model Chat {
  idChat      String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  title       String      @default("Nova Conversa")
  messages    Message[]
  chatLogs    ChatLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  active      Boolean     @default(true)

  @@index([userId])
  @@index([createdAt])
}

model Message {
  idMessage   String      @id @default(uuid())
  chatId      String
  chat        Chat        @relation(fields: [chatId], references: [idChat], onDelete: Cascade)
  role        ChatRole
  content     String      @db.Text
  createdAt   DateTime    @default(now())

  @@index([chatId])
  @@index([createdAt])
}

// ========================================
// AI Agents & Triggers System
// ========================================

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ========================================
// Groups (compartilhamento de dados entre profissionais)
// ========================================

model Grupo {
  idGrupo     Int            @id @default(autoincrement())
  nome        String
  descricao   String?
  isDefault   Boolean        @default(false)
  createdById String?
  createdBy   User?          @relation("GrupoCreator", fields: [createdById], references: [idUser])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  membros     Grupo_Membro[]
  pacientes   User[]         @relation("GrupoPacientes")
  formularios Form[]         @relation("GrupoFormularios")

  // Módulo hospitalar
  plantoes     Plantao[]     @relation("PlantaoGrupo")
  queueTickets QueueTicket[] @relation("QueueGrupo")
  supplies     Supply[]      @relation("SupplyGrupo")

  @@index([createdById])
  @@index([isDefault])
}

model Grupo_Membro {
  id       Int      @id @default(autoincrement())
  grupoId  Int
  userId   String
  joinedAt DateTime @default(now())

  grupo Grupo @relation(fields: [grupoId], references: [idGrupo], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  @@unique([grupoId, userId])
  @@index([grupoId])
  @@index([userId])
}

model AiAgent {
  id              String      @id @default(uuid())
  name            String      @unique
  description     String?
  model           String      @default("gpt-4o-mini")  // Modelo de IA usado
  temperature     Float       @default(0.7)
  maxTokens       Int         @default(2048)
  systemPrompt    String?     @db.Text  // Prompt base do agente
  active          Boolean     @default(true)
  isDefault       Boolean     @default(false)  // Se é o agente padrão
  
  triggers        AiTrigger[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([active])
  @@index([isDefault])
}

model AiTrigger {
  id              String      @id @default(uuid())
  triggerId       String      @unique @default(uuid()) // ID único legível (ex: "form-creation")
  name            String
  description     String?
  
  // Configurações de ativação
  minScore        Int         @default(5)
  priority        Int         @default(10)  // Menor = maior prioridade
  active          Boolean     @default(true)
  canStack        Boolean     @default(false)
  
  // Prompt específico da trigger
  systemPrompt    String      @db.Text
  temperature     Float?      // Se null, usa do agente
  maxTokens       Int?        // Se null, usa do agente
  
  // Marcadores especiais (ex: ["GERAR-FORM-159753"])
  markers         String[]    @default([])
  
  // Relação com agente
  agentId         String
  agent           AiAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Keywords
  keywords        AiTriggerKeyword[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([agentId])
  @@index([active])
  @@index([priority])
}

model AiTriggerKeyword {
  id          String      @id @default(uuid())
  word        String
  weight      Int         @default(5)

  triggerId   String
  trigger     AiTrigger   @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([triggerId])
  @@unique([triggerId, word])
}

// ========================================
// Chat Analytics / Logs
// ========================================

enum ChatLogType {
  TRIGGER_DETECTED
  MARKER_PROCESSED
  ACTION_SUCCESS
  ACTION_ERROR
  MESSAGE_SENT
  MESSAGE_RECEIVED
}

model ChatLog {
  id            String      @id @default(uuid())
  chatId        String
  chat          Chat        @relation(fields: [chatId], references: [idChat], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [idUser])
  type          ChatLogType
  triggerName   String?
  triggerId     String?
  score         Float?
  marker        String?
  actionResult  String?     @db.Text
  errorMessage  String?     @db.Text
  userMessage   String?     @db.Text
  aiResponse    String?     @db.Text
  metadata      Json?
  duration      Int?
  createdAt     DateTime    @default(now())

  @@index([chatId])
  @@index([userId])
  @@index([type])
  @@index([triggerName])
  @@index([createdAt])
}

// ============================================================
// Módulo de Gestão Hospitalar (Grupo = Hospital)
// ============================================================

enum DoctorStatus {
  Ativo
  Afastado
  Ferias
  Inativo
}

enum PlantaoStatus {
  Aberto // disponível no mercado — qualquer médico do grupo pode pegar
  Agendado // atribuído a um médico
  EmAndamento
  Concluido
  Cancelado
}

/// Turno de plantão em um setor. Pode estar "Aberto" (sem médico) para um
/// médico do grupo pegar, ou atribuído a um médico (User com type = MEDICO).
model Plantao {
  id         String        @id @default(cuid())
  doctorId   String?
  grupoId    Int?
  setor      String
  startsAt   DateTime
  endsAt     DateTime
  status     PlantaoStatus @default(Aberto)
  checkinAt  DateTime?
  checkoutAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  doctor User?  @relation("PlantaoDoctor", fields: [doctorId], references: [idUser], onDelete: SetNull)
  grupo  Grupo? @relation("PlantaoGrupo", fields: [grupoId], references: [idGrupo])

  @@index([doctorId])
  @@index([grupoId])
  @@index([startsAt])
  @@index([status])
}

enum QueuePriority {
  Normal
  Preferencial
  Urgencia
}

enum QueueStatus {
  Aguardando
  Chamado
  EmAtendimento
  Concluido
  Cancelado
  Faltou
}

/// Senha/ticket da fila de atendimento.
model QueueTicket {
  id          String        @id @default(cuid())
  grupoId     Int?
  code        String // ex: A-102
  patientId   String?
  patientName String? // fallback quando não há cadastro
  setor       String
  priority    QueuePriority @default(Normal)
  status      QueueStatus   @default(Aguardando)
  doctorId    String? // User id do médico que assumiu
  issuedAt    DateTime      @default(now())
  calledAt    DateTime?
  confirmedAt DateTime?
  closedAt    DateTime?

  patient User?  @relation("QueuePatient", fields: [patientId], references: [idUser])
  doctor  User?  @relation("QueueDoctor", fields: [doctorId], references: [idUser])
  grupo   Grupo? @relation("QueueGrupo", fields: [grupoId], references: [idGrupo])

  @@index([grupoId])
  @@index([status])
  @@index([issuedAt])
}

/// Insumo de estoque hospitalar.
model Supply {
  id        String    @id @default(cuid())
  grupoId   Int?
  name      String
  unit      String // un, cx, L...
  balance   Int       @default(0)
  minStock  Int       @default(0)
  lot       String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  grupo     Grupo?           @relation("SupplyGrupo", fields: [grupoId], references: [idGrupo])
  movements SupplyMovement[]

  @@index([grupoId])
}

enum SupplyMovementType {
  Entrada
  Saida
}

/// Movimentação de estoque (entrada/saída).
model SupplyMovement {
  id           String             @id @default(cuid())
  supplyId     String
  type         SupplyMovementType
  quantity     Int
  reason       String?
  attendanceId String?
  userId       String?
  createdAt    DateTime           @default(now())

  supply Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@index([supplyId])
  @@index([type])
  @@index([createdAt])
}
